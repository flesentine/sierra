/scummvm.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=0, must-revalidate

/scummvm.js
  Cache-Control: public, max-age=0, must-revalidate

/scummvm.js?v=*
  Cache-Control: public, max-age=0, must-revalidate

/scummvm.wasm?v=*
  Content-Type: application/wasm
  Cache-Control: public, max-age=0, must-revalidate

/data/*
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=3600

/index.html
  Cache-Control: no-cache

/scummvm.html
  Cache-Control: no-cache

/scummvm.html?v=*
  Cache-Control: no-cache

/game.html
  Cache-Control: no-cache

/game.html?v=*
  Cache-Control: no-cache
